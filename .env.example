# Copy this file to .env and fill in real values, then run `npm run deploy`
# (or `npm run secrets:sync` on its own) to push any of these missing from
# your Cloudflare Worker's secrets. .env is gitignored - never commit real
# values. See README.md "Setup" for where each one comes from.

# From PurpleAir (email contact@purpleair.com for a read key)
PURPLEAIR_API_KEY=

# From @BotFather on Telegram, after /newbot
TELEGRAM_BOT_TOKEN=

# You generate this yourself, e.g. `openssl rand -hex 24`
TELEGRAM_WEBHOOK_SECRET=

# You generate this yourself too, e.g. `openssl rand -hex 24`
ADMIN_TOKEN=

# Your bot's @username (no @), e.g. MyAqiBot - shown in @BotFather and in the
# bot's Telegram profile. Not a security secret, but kept out of the public
# repo the same way since it identifies the specific bot. Used to build a
# shareable https://t.me/<username> link in subscription confirmations.
TELEGRAM_BOT_USERNAME=

# Your deployed Worker's URL, printed by `wrangler deploy` / `npm run deploy`
# (e.g. https://purple-air-notification.<your-subdomain>.workers.dev).
# Used by scripts/set-webhook.sh - not a secret, just convenient to keep here.
WORKER_URL=
